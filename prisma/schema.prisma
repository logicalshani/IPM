generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum FeatureStatus {
  ENABLED
  DISABLED
}

enum StocktakeStatus {
  DRAFT
  IN_PROGRESS
  PENDING_APPROVAL
  APPROVED
  SYNCED
}

enum CountMode {
  FULL
  PARTIAL
  BLIND
  CYCLE
}

enum StocktakeLineStatus {
  OPEN
  NEEDS_INVESTIGATION
  CONFIRMED
  RECOUNT
  APPROVED
  REJECTED
}

enum BarcodeFormat {
  EAN_13
  CODE_128
  QR_CODE
  DATA_MATRIX
}

enum MovementType {
  SALE
  RETURN
  RECEIVING
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  DAMAGE
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  SENT_TO_SUPPLIER
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  INVOICED
  RECEIVED
  CLOSED
  CANCELLED
  DISPUTED
}

enum PurchaseOrderApprovalRole {
  MANAGER
  OWNER
}

enum PurchaseOrderApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
}

enum BackorderRecommendation {
  WAIT_FOR_BACKORDER
  SOURCE_ALTERNATE
  ADJUST_SHOPIFY_AVAILABILITY
}

enum ContractStatus {
  ACTIVE
  EXPIRING
  EXPIRED
  ARCHIVED
}

enum CommunicationChannel {
  EMAIL
  WHATSAPP
  PHONE
  NOTE
}

enum CommunicationDirection {
  OUTBOUND
  INBOUND
}

enum SupplierEmailIntent {
  PO_FOLLOW_UP
  DELAY_INQUIRY
  PRICE_NEGOTIATION
  INVOICE_DISPUTE
  RETURN_REQUEST
}

enum AIFeedbackRating {
  THUMBS_UP
  THUMBS_DOWN
}

enum ForecastSignalType {
  GOOGLE_TRENDS
  SHOPIFY_DISCOUNT
  RETURN_RATE
  SEASONALITY
  RESTOCK_HALO
  MERCHANT_PROXY
}

enum InvoiceReviewStatus {
  PARSED
  MATCHED
  APPROVED
  FLAGGED
  EXPORTED
}

enum InventoryValuationMethod {
  FIFO
  LIFO
  WEIGHTED_AVERAGE
}

enum InventoryAdjustmentReason {
  DAMAGED
  STOLEN
  EXPIRED
  DATA_ERROR
  CORRECTION
}

enum ReturnCondition {
  RESELLABLE
  DAMAGED
  DEFECTIVE
  SUPPLIER_FAULT
}

enum RestockingDecision {
  RESTOCK_NEW
  RESTOCK_OPEN_BOX
  LIQUIDATE
  DISPOSE
}

enum RmaStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  CLOSED
}

enum BatchDisposition {
  AVAILABLE
  EXPIRING
  EXPIRED
  RECALL
  DISPOSED
  DISCOUNT
}

enum ThreePLProvider {
  SHIPBOB
  FLEXPORT
  DELIVERR
  AMAZON_FBA
  WEBHOOK
}

enum WarehouseSyncStatus {
  MATCHED
  DISCREPANCY
  UPDATED_SHOPIFY
}

enum TransferStatus {
  SUGGESTED
  DRAFT
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum ReportVisualization {
  TABLE
  BAR
  LINE
  PIE
}

enum ReportScheduleFrequency {
  WEEKLY
  MONTHLY
}

enum IntegrationProvider {
  SHOPIFY
  QUICKBOOKS_ONLINE
  XERO
  SLACK
  MICROSOFT_TEAMS
  PUBLIC_API
}

enum IntegrationStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  ERROR
}

enum SyncDirection {
  INBOUND
  OUTBOUND
}

enum SyncLogStatus {
  SUCCESS
  FAILED
  RETRYING
}

enum AccountingExportType {
  INVENTORY_VALUATION
  COGS_ENTRY
  PURCHASE_ORDER_BILL
  JOURNAL_ENTRY
}

enum MobileSyncStatus {
  QUEUED
  SYNCED
  FAILED
}

enum WhiteLabelStatus {
  DRAFT
  ACTIVE
  SUSPENDED
}

enum ManagedStoreStatus {
  CONNECTED
  SYNCING
  DISCONNECTED
  ERROR
}

enum CrossStoreTransferStatus {
  SUGGESTED
  APPROVED
  IN_TRANSIT
  COMPLETED
  DISMISSED
}

enum AccessRole {
  OWNER
  ADMIN
  INVENTORY_MANAGER
  PURCHASING_MANAGER
  WAREHOUSE_STAFF
  AUDITOR
}

enum AuditSyncStatus {
  NOT_SYNCED
  SUCCESS
  FAILED
  PENDING
}

enum BillingPlanKey {
  STARTER
  GROWTH
  PRO
  AGENCY
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum MigrationJobStatus {
  DRAFT
  VALIDATING
  READY
  RUNNING
  COMPLETED
  FAILED
  ROLLED_BACK
}

enum MigrationEntityType {
  SUPPLIERS
  PRODUCTS
  PURCHASE_ORDERS
  STOCK_COUNTS
  TRANSFERS
  HISTORICAL_DATA
}

enum AIMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

model Shop {
  id                            String                         @id @default(cuid())
  shopifyDomain                 String                         @unique
  name                          String
  billingPlan                   String                         @default("starter")
  features                      Feature[]
  users                         User[]
  locations                     Location[]
  products                      Product[]
  stocktakes                    StocktakeSession[]
  barcodeAssets                 BarcodeAsset[]
  suppliers                     Supplier[]
  aiSessions                    AIConsultationSession[]
  demandForecasts               DemandForecast[]
  parsedInvoices                ParsedInvoice[]
  profitScenarios               ProfitScenario[]
  competitorProducts            CompetitorProduct[]
  financialSettings             FinancialSettings?
  inventoryCostLayers           InventoryCostLayer[]
  inventoryAdjustments          InventoryAdjustment[]
  financialAlerts               FinancialAlert[]
  returnIntakes                 ReturnIntake[]
  supplierRmas                  SupplierRma[]
  inventoryBatches              InventoryBatch[]
  threePLConnections            ThreePLConnection[]
  threePLSnapshots              ThreePLInventorySnapshot[]
  transferSuggestions           InventoryTransferSuggestion[]
  inventoryTransfers            InventoryTransfer[]
  customReports                 CustomReport[]
  scheduledReports              ScheduledReport[]
  integrationConnections        IntegrationConnection[]
  syncLogs                      SyncLog[]
  shopifyWebhookEvents          ShopifyWebhookEvent[]
  shopifyMetafieldSyncs         ShopifyMetafieldSync[]
  shopifyFlowEvents             ShopifyFlowEvent[]
  accountingExports             AccountingExport[]
  chatConnections               ChatBotConnection[]
  mobileOfflineSyncs            MobileOfflineSync[]
  publicApiKeys                 PublicApiKey[]
  outboundWebhookSubscriptions  OutboundWebhookSubscription[]
  whiteLabelProfile             WhiteLabelProfile?
  managedStores                 ManagedStore[]
  crossStoreTransferSuggestions CrossStoreTransferSuggestion[]
  aiMemoryEvents                AIMemoryEvent[]
  aiPinnedInsights              AIPinnedInsight[]
  rolePermissions               RolePermission[]
  userRoleAssignments           UserRoleAssignment[]
  complianceAuditLogs           ComplianceAuditLog[]
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
}

model Feature {
  id        String        @id @default(cuid())
  shopId    String
  key       String
  plan      String
  status    FeatureStatus @default(DISABLED)
  config    Json?
  shop      Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([shopId, key])
}

model User {
  id                   String                @id @default(cuid())
  shopId               String
  name                 String
  email                String
  role                 String                @default("operator")
  shop                 Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  assignments          StocktakeSession[]    @relation("StocktakeAssignee")
  approvals            StocktakeSession[]    @relation("StocktakeApprover")
  inventoryAdjustments InventoryAdjustment[]
  accessRoles          UserRoleAssignment[]
  auditLogs            ComplianceAuditLog[]

  @@unique([shopId, email])
}

model Location {
  id                   String                @id @default(cuid())
  shopId               String
  shopifyLocationId    String?
  name                 String
  barcode              String?
  shop                 Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products             ProductInventory[]
  stocktakes           StocktakeSession[]
  inventoryAdjustments InventoryAdjustment[]
  inventoryBatches     InventoryBatch[]
  inventoryLevels      InventoryLevel[]

  @@unique([shopId, name])
}

model Product {
  id                      String                            @id @default(cuid())
  shopId                  String
  supplierId              String?
  shopifyProductId        String?
  shopifyVariantId        String?
  sku                     String
  name                    String
  category                String?
  supplier                String?
  price                   Decimal                           @db.Decimal(12, 2)
  cost                    Decimal                           @db.Decimal(12, 2)
  barcode                 String?
  expiryDate              DateTime?
  shop                    Shop                              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplierRecord          Supplier?                         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  inventory               ProductInventory[]
  movements               InventoryMovement[]
  stocktakeLines          StocktakeLine[]
  barcodeAssets           BarcodeAsset[]
  purchaseOrderLines      PurchaseOrderLine[]
  priceListItems          SupplierPriceListItem[]
  demandProfile           ProductDemandProfile?
  demandForecasts         DemandForecast[]
  forecastAccuracy        ForecastAccuracy[]
  parsedInvoiceLines      ParsedInvoiceLine[]
  profitScenarioOptions   ProfitScenarioOption[]
  competitorProducts      CompetitorProduct[]
  sourcingOptions         ProductSupplierOption[]
  costLayers              InventoryCostLayer[]
  inventoryAdjustments    InventoryAdjustment[]
  returnIntakes           ReturnIntake[]
  inventoryBatches        InventoryBatch[]
  threePLSnapshots        ThreePLInventorySnapshot[]
  transferSuggestionLines InventoryTransferSuggestionLine[]
  transferLines           InventoryTransferLine[]
  replenishmentRules      LocationReplenishmentRule[]
  shopifyMetafieldSyncs   ShopifyMetafieldSync[]
  variants                ProductVariant[]

  @@unique([shopId, sku])
  @@index([shopId, category])
  @@index([shopId, supplier])
  @@index([shopId, supplierId])
}

model ProductInventory {
  id                String   @id @default(cuid())
  productId         String
  locationId        String
  quantity          Int      @default(0)
  inTransitQuantity Int      @default(0)
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  location          Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
}

model InventoryMovement {
  id         String       @id @default(cuid())
  shopId     String
  productId  String
  locationId String?
  type       MovementType
  quantity   Int
  unitCost   Decimal      @db.Decimal(12, 2)
  reference  String?
  notes      String?
  occurredAt DateTime     @default(now())
  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([shopId, productId, occurredAt])
}

model StocktakeSession {
  id                       String          @id @default(cuid())
  shopId                   String
  name                     String
  locationId               String?
  assignedUserId           String?
  approvedById             String?
  scheduledDate            DateTime?
  status                   StocktakeStatus @default(DRAFT)
  mode                     CountMode       @default(FULL)
  filters                  Json?
  blindCount               Boolean         @default(false)
  varianceThresholdPercent Decimal         @default(5) @db.Decimal(5, 2)
  varianceThresholdValue   Decimal         @default(50) @db.Decimal(12, 2)
  shop                     Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  location                 Location?       @relation(fields: [locationId], references: [id])
  assignedUser             User?           @relation("StocktakeAssignee", fields: [assignedUserId], references: [id])
  approvedBy               User?           @relation("StocktakeApprover", fields: [approvedById], references: [id])
  lines                    StocktakeLine[]
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  @@index([shopId, status])
  @@index([shopId, scheduledDate])
}

model StocktakeLine {
  id                String              @id @default(cuid())
  sessionId         String
  productId         String
  expectedQuantity  Int
  countedQuantity   Int?
  averagedQuantity  Decimal?            @db.Decimal(12, 2)
  varianceUnits     Int                 @default(0)
  varianceValue     Decimal             @default(0) @db.Decimal(12, 2)
  variancePercent   Decimal             @default(0) @db.Decimal(8, 2)
  status            StocktakeLineStatus @default(OPEN)
  countSource       String?
  investigationNote String?
  lastCountedAt     DateTime?
  session           StocktakeSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  product           Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([sessionId, productId])
  @@index([sessionId, status])
}

model BarcodeTemplate {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  widthMm   Int
  heightMm  Int
  fields    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shopId, name])
}

model BarcodeAsset {
  id        String        @id @default(cuid())
  shopId    String
  productId String?
  format    BarcodeFormat
  value     String
  imageData String
  shop      Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product   Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())

  @@index([shopId, format])
}

model Supplier {
  id                       String                        @id @default(cuid())
  shopId                   String
  name                     String
  email                    String?
  phone                    String?
  whatsappNumber           String?
  defaultCurrency          String                        @default("USD")
  paymentTerms             String?
  reliabilityScore         Decimal                       @default(0) @db.Decimal(5, 2)
  previousReliabilityScore Decimal                       @default(0) @db.Decimal(5, 2)
  onTimeRate               Decimal                       @default(0) @db.Decimal(5, 2)
  fillRate                 Decimal                       @default(0) @db.Decimal(5, 2)
  invoiceAccuracy          Decimal                       @default(0) @db.Decimal(5, 2)
  notes                    String?
  shop                     Shop                          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products                 Product[]
  leadTimes                SupplierCategoryLeadTime[]
  purchaseOrders           PurchaseOrder[]
  reliabilitySnapshots     SupplierReliabilitySnapshot[]
  seasonalRiskPeriods      SupplierSeasonalRiskPeriod[]
  priceLists               SupplierPriceList[]
  contracts                SupplierContract[]
  communications           SupplierCommunication[]
  sourcingOptions          ProductSupplierOption[]
  rmas                     SupplierRma[]
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt

  @@unique([shopId, name])
  @@index([shopId, reliabilityScore])
}

model SupplierCategoryLeadTime {
  id                       String   @id @default(cuid())
  shopId                   String
  supplierId               String
  category                 String
  minimumDays              Int
  maximumDays              Int
  averageDays              Decimal  @db.Decimal(8, 2)
  rolling90DayAverage      Decimal? @db.Decimal(8, 2)
  dynamicEstimateDays      Decimal  @default(0) @db.Decimal(8, 2)
  bufferDays               Int      @default(0)
  recentDegradationPercent Decimal  @default(0) @db.Decimal(8, 2)
  supplier                 Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  updatedAt                DateTime @updatedAt
  createdAt                DateTime @default(now())

  @@unique([supplierId, category])
  @@index([shopId, category])
}

model SupplierSeasonalRiskPeriod {
  id         String    @id @default(cuid())
  shopId     String
  supplierId String?
  name       String
  startsOn   DateTime
  endsOn     DateTime
  bufferDays Int
  notes      String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([shopId, startsOn, endsOn])
}

model PurchaseOrder {
  id                      String                    @id @default(cuid())
  shopId                  String
  supplierId              String
  poNumber                String
  status                  PurchaseOrderStatus       @default(DRAFT)
  approvalTier            String?
  approvedAt              DateTime?
  sentAt                  DateTime?
  closedAt                DateTime?
  cancelledAt             DateTime?
  orderedAt               DateTime                  @default(now())
  promisedDeliveryDate    DateTime?
  actualDeliveryDate      DateTime?
  deliveryDeltaDays       Int?
  invoiceAccurate         Boolean?
  invoiceTotal            Decimal?                  @db.Decimal(12, 2)
  expectedTotal           Decimal?                  @db.Decimal(12, 2)
  subtotal                Decimal                   @default(0) @db.Decimal(12, 2)
  freightCost             Decimal                   @default(0) @db.Decimal(12, 2)
  customsCost             Decimal                   @default(0) @db.Decimal(12, 2)
  handlingCost            Decimal                   @default(0) @db.Decimal(12, 2)
  landedTotal             Decimal                   @default(0) @db.Decimal(12, 2)
  trackingNumber          String?
  supplierEmailMessageId  String?
  threeWayMatchJson       Json?
  backorderRecommendation BackorderRecommendation?
  notes                   String?
  supplier                Supplier                  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  lines                   PurchaseOrderLine[]
  parsedInvoices          ParsedInvoice[]
  approvals               PurchaseOrderApproval[]
  backorderReminders      BackorderReminder[]
  landedCostLines         PurchaseOrderLandedCost[]
  canonicalItems          PurchaseOrderItem[]
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt

  @@unique([shopId, poNumber])
  @@index([shopId, supplierId, orderedAt])
  @@index([shopId, actualDeliveryDate])
}

model PurchaseOrderLine {
  id                    String        @id @default(cuid())
  purchaseOrderId       String
  productId             String?
  sku                   String
  category              String
  orderedQuantity       Int
  receivedQuantity      Int           @default(0)
  backorderedQuantity   Int           @default(0)
  unitPrice             Decimal       @db.Decimal(12, 2)
  landedUnitCost        Decimal?      @db.Decimal(12, 2)
  marginAfterLandedCost Decimal?      @db.Decimal(12, 2)
  invoiceUnitPrice      Decimal?      @db.Decimal(12, 2)
  invoiceQuantity       Int?
  priceVariance         Decimal       @default(0) @db.Decimal(12, 2)
  receivedAt            DateTime?
  disputed              Boolean       @default(false)
  disputeReason         String?
  purchaseOrder         PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product               Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId, category])
}

model ProductSupplierOption {
  id           String   @id @default(cuid())
  shopId       String
  productId    String
  supplierId   String
  supplierSku  String?
  unitPrice    Decimal  @db.Decimal(12, 2)
  moq          Int      @default(1)
  leadTimeDays Decimal  @db.Decimal(8, 2)
  active       Boolean  @default(true)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([productId, supplierId])
  @@index([shopId, supplierId])
}

model PurchaseOrderApprovalPolicy {
  id           String                     @id @default(cuid())
  shopId       String
  name         String
  minAmount    Decimal                    @db.Decimal(12, 2)
  maxAmount    Decimal?                   @db.Decimal(12, 2)
  requiredRole PurchaseOrderApprovalRole?
  autoApprove  Boolean                    @default(false)
  active       Boolean                    @default(true)

  @@index([shopId, active])
}

model PurchaseOrderApproval {
  id              String                      @id @default(cuid())
  shopId          String
  purchaseOrderId String
  requiredRole    PurchaseOrderApprovalRole?
  approverUserId  String?
  status          PurchaseOrderApprovalStatus @default(PENDING)
  token           String                      @unique
  requestedAt     DateTime                    @default(now())
  decidedAt       DateTime?
  note            String?
  purchaseOrder   PurchaseOrder               @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([shopId, purchaseOrderId, status])
}

model PurchaseOrderLandedCost {
  id              String        @id @default(cuid())
  shopId          String
  purchaseOrderId String
  type            String
  amount          Decimal       @db.Decimal(12, 2)
  allocationBasis String        @default("quantity")
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@index([shopId, purchaseOrderId])
}

model BackorderReminder {
  id                  String                   @id @default(cuid())
  shopId              String
  purchaseOrderId     String
  purchaseOrderLineId String?
  supplierId          String
  sku                 String
  quantity            Int
  dueAt               DateTime
  status              String                   @default("open")
  recommendation      BackorderRecommendation?
  note                String?
  purchaseOrder       PurchaseOrder            @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  createdAt           DateTime                 @default(now())

  @@index([shopId, dueAt, status])
}

model SupplierReliabilitySnapshot {
  id               String   @id @default(cuid())
  shopId           String
  supplierId       String
  month            DateTime
  category         String?
  onTimeRate       Decimal  @db.Decimal(5, 2)
  fillRate         Decimal  @db.Decimal(5, 2)
  invoiceAccuracy  Decimal  @db.Decimal(5, 2)
  reliabilityScore Decimal  @db.Decimal(5, 2)
  averageDelayDays Decimal  @db.Decimal(8, 2)
  supplier         Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, month, category])
  @@index([shopId, month])
}

model SupplierPriceList {
  id            String                  @id @default(cuid())
  shopId        String
  supplierId    String
  name          String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  currency      String                  @default("USD")
  supplier      Supplier                @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items         SupplierPriceListItem[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([shopId, supplierId, effectiveFrom])
}

model SupplierPriceListItem {
  id                 String            @id @default(cuid())
  priceListId        String
  productId          String?
  sku                String
  moq                Int               @default(1)
  unitPrice          Decimal           @db.Decimal(12, 2)
  previousUnitPrice  Decimal?          @db.Decimal(12, 2)
  priceChangePercent Decimal           @default(0) @db.Decimal(8, 2)
  marginImpact       Decimal           @default(0) @db.Decimal(12, 2)
  priceList          SupplierPriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product            Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([priceListId, sku])
}

model SupplierContract {
  id                 String         @id @default(cuid())
  shopId             String
  supplierId         String
  title              String
  status             ContractStatus @default(ACTIVE)
  effectiveDate      DateTime?
  renewalDate        DateTime?
  paymentTerms       String?
  moqTerms           String?
  leadTimeCommitment String?
  returnPolicy       String?
  exclusivityClauses String?
  aiSummary          String?
  sourceFileName     String?
  supplier           Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([shopId, renewalDate])
}

model SupplierCommunication {
  id         String                 @id @default(cuid())
  shopId     String
  supplierId String
  channel    CommunicationChannel
  direction  CommunicationDirection
  intent     SupplierEmailIntent?
  subject    String?
  body       String
  externalId String?
  status     String                 @default("draft")
  sentAt     DateTime?
  createdAt  DateTime               @default(now())
  supplier   Supplier               @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([shopId, supplierId, createdAt])
}

model AIConsultationSession {
  id              String            @id @default(cuid())
  shopId          String
  userId          String?
  question        String
  answer          String?
  dataSnapshot    Json
  intent          String
  confidence      String
  suggestedAction String
  feedback        AIFeedbackRating?
  feedbackNote    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  shop            Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  pinnedInsights  AIPinnedInsight[]

  @@index([shopId, createdAt])
}

model ProductDemandProfile {
  id                    String    @id @default(cuid())
  shopId                String
  productId             String    @unique
  baselineDailyDemand   Decimal   @default(0) @db.Decimal(10, 2)
  salesVelocity30d      Decimal   @default(0) @db.Decimal(10, 2)
  returnRate            Decimal   @default(0) @db.Decimal(5, 2)
  activeDiscountPercent Decimal   @default(0) @db.Decimal(5, 2)
