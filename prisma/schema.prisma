  shopifySyncStatus AuditSyncStatus @default(NOT_SYNCED)
  shopifySyncResult Json?
  previousHash      String?
  recordHash        String
  timestamp         DateTime        @default(now())
  shop              Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user              User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([shopId, timestamp])
  @@index([shopId, actionType])
  @@index([shopId, entityModel, entityId])
  @@index([shopId, userId])
}

model Store {
  id            String   @id @default(cuid())
  shopId        String
  shopifyDomain String   @unique
  name          String
  timezone      String   @default("UTC")
  currency      String   @default("USD")
  status        String   @default("ACTIVE")
  settings      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([shopId, status])
}

model Role {
  id          String   @id @default(cuid())
  shopId      String
  key         String
  name        String
  rank        Int
  description String?
  system      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shopId, key])
  @@index([shopId, rank])
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  module      String
  action      String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductVariant {
  id                 String              @id @default(cuid())
  shopId             String
  productId          String
  shopifyVariantId   String?
  sku                String
  title              String
  optionValues       Json?
  barcode            String?
  price              Decimal             @db.Decimal(12, 2)
  cost               Decimal             @db.Decimal(12, 2)
  weightGrams        Int?
  active             Boolean             @default(true)
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryLevels    InventoryLevel[]
  purchaseItems      PurchaseOrderItem[]
  stockCountItems    StockCountItem[]
  transferItems      StockTransferItem[]
  returnItems        ReturnItem[]
  forecasts          Forecast[]
  reorderSuggestions ReorderSuggestion[]
  competitorPrices   CompetitorPrice[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([shopId, sku])
  @@index([productId, active])
}

model InventoryLevel {
  id                     String         @id @default(cuid())
  shopId                 String
  variantId              String
  locationId             String
  shopifyInventoryItemId String?
  available              Int            @default(0)
  committed              Int            @default(0)
  incoming               Int            @default(0)
  reserved               Int            @default(0)
  safetyStock            Int            @default(0)
  reorderPoint           Int            @default(0)
  reorderQuantity        Int            @default(0)
  lastSyncedAt           DateTime?
  variant                ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  location               Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@unique([variantId, locationId])
  @@index([shopId, locationId])
}

model PurchaseOrderItem {
  id               String          @id @default(cuid())
  shopId           String
  purchaseOrderId  String
  variantId        String?
  sku              String
  title            String?
  quantityOrdered  Int
  quantityReceived Int             @default(0)
  unitCost         Decimal         @db.Decimal(12, 2)
  taxAmount        Decimal         @default(0) @db.Decimal(12, 2)
  landedUnitCost   Decimal?        @db.Decimal(12, 2)
  status           String          @default("OPEN")
  purchaseOrder    PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([shopId, purchaseOrderId])
  @@index([shopId, sku])
}

model StockTransfer {
  id             String              @id @default(cuid())
  shopId         String
  transferNumber String
  fromLocationId String
  toLocationId   String
  status         TransferStatus      @default(DRAFT)
  reason         String?
  createdBy      String?
  shippedAt      DateTime?
  receivedAt     DateTime?
  items          StockTransferItem[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([shopId, transferNumber])
  @@index([shopId, status])
}

model StockTransferItem {
  id               String          @id @default(cuid())
  shopId           String
  stockTransferId  String
  variantId        String?
  sku              String
  quantity         Int
  receivedQuantity Int             @default(0)
  stockTransfer    StockTransfer   @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([shopId, stockTransferId])
}

model StockCount {
  id          String           @id @default(cuid())
  shopId      String
  name        String
  locationId  String?
  mode        CountMode        @default(FULL)
  status      StocktakeStatus  @default(DRAFT)
  blindCount  Boolean          @default(false)
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  approvedAt  DateTime?
  createdBy   String?
  approvedBy  String?
  items       StockCountItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([shopId, status])
  @@index([shopId, locationId])
}

model StockCountItem {
  id               String          @id @default(cuid())
  shopId           String
  stockCountId     String
  variantId        String?
  sku              String
  expectedQuantity Int
  countedQuantity  Int?
  varianceUnits    Int             @default(0)
  varianceValue    Decimal         @default(0) @db.Decimal(12, 2)
  status           String          @default("OPEN")
  notes            String?
  stockCount       StockCount      @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([stockCountId, sku])
  @@index([shopId, status])
}

model BatchLot {
  id                String           @id @default(cuid())
  shopId            String
  variantId         String?
  locationId        String
  lotNumber         String
  expiryDate        DateTime?
  receivedAt        DateTime         @default(now())
  quantityReceived  Int
  quantityRemaining Int
  disposition       BatchDisposition @default(AVAILABLE)
  recallStatus      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([shopId, lotNumber, locationId])
  @@index([shopId, expiryDate])
}

model ReturnRecord {
  id              String       @id @default(cuid())
  shopId          String
  returnNumber    String
  orderName       String?
  customerEmail   String?
  salesChannel    String       @default("Shopify")
  status          String       @default("OPEN")
  receivedAt      DateTime?
  restockingNotes String?
  items           ReturnItem[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([shopId, returnNumber])
  @@index([shopId, status])
}

model ReturnItem {
  id                 String              @id @default(cuid())
  shopId             String
  returnRecordId     String
  variantId          String?
  sku                String
  quantity           Int
  condition          ReturnCondition
  restockingDecision RestockingDecision?
  supplierFault      Boolean             @default(false)
  returnRecord       ReturnRecord        @relation(fields: [returnRecordId], references: [id], onDelete: Cascade)
  variant            ProductVariant?     @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([shopId, condition])
}

model Forecast {
  id             String                      @id @default(cuid())
  shopId         String
  variantId      String
  forecastDate   DateTime                    @default(now())
  horizonDays    Int
  baselineDemand Decimal                     @db.Decimal(12, 2)
  adjustedDemand Decimal                     @db.Decimal(12, 2)
  confidence     String                      @default("Medium")
  modelVersion   String                      @default("imp-demand-v1")
  inputs         Json?
  variant        ProductVariant              @relation(fields: [variantId], references: [id], onDelete: Cascade)
  accuracies     ForecastAccuracyCanonical[]
  createdAt      DateTime                    @default(now())

  @@index([shopId, forecastDate])
  @@index([variantId, horizonDays])
}

model ForecastAccuracyCanonical {
  id            String   @id @default(cuid())
  shopId        String
  forecastId    String
  periodStart   DateTime
  periodEnd     DateTime
  forecastUnits Decimal  @db.Decimal(12, 2)
  actualUnits   Decimal  @db.Decimal(12, 2)
  mape          Decimal  @db.Decimal(8, 2)
  notes         String?
  forecast      Forecast @relation(fields: [forecastId], references: [id], onDelete: Cascade)

  @@index([shopId, periodStart])
}

model ReorderSuggestion {
  id               String         @id @default(cuid())
  shopId           String
  variantId        String
  supplierId       String?
  quantity         Int
  estimatedCost    Decimal        @db.Decimal(12, 2)
  daysOfStockLeft  Decimal        @db.Decimal(8, 2)
  priorityScore    Decimal        @db.Decimal(8, 2)
  status           String         @default("REVIEW")
  reason           String
  generatedByJobId String?
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([shopId, status, priorityScore])
}

model Alert {
  id             String        @id @default(cuid())
  shopId         String
  ruleId         String?
  severity       AlertSeverity
  status         AlertStatus   @default(OPEN)
  title          String
  message        String
  entityModel    String?
  entityId       String?
  firedAt        DateTime      @default(now())
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  rule           AlertRule?    @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([shopId, status, severity])
}

model AlertRule {
  id        String        @id @default(cuid())
  shopId    String
  name      String
  metric    String
  operator  String
  threshold Decimal       @db.Decimal(12, 2)
  severity  AlertSeverity @default(WARNING)
  channels  Json
  enabled   Boolean       @default(true)
  alerts    Alert[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([shopId, name])
  @@index([shopId, enabled])
}

model Report {
  id            String              @id @default(cuid())
  shopId        String
  name          String
  reportKey     String
  dimensions    Json
  metrics       Json
  filters       Json?
  visualization ReportVisualization @default(TABLE)
  createdBy     String?
  schedules     ReportSchedule[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([shopId, name])
}

model ReportSchedule {
  id             String                  @id @default(cuid())
  shopId         String
  reportId       String
  frequency      ReportScheduleFrequency @default(WEEKLY)
  recipientEmail String
  active         Boolean                 @default(true)
  nextRunAt      DateTime?
  lastRunAt      DateTime?
  report         Report                  @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([shopId, active, nextRunAt])
}

model BillingPlan {
  id                String         @id @default(cuid())
  key               BillingPlanKey @unique
  name              String
  monthlyPriceCents Int
  skuLimit          Int?
  locationLimit     Int?
  storeLimit        Int?
  features          Json
  overageSkuCents   Int            @default(1)
  active            Boolean        @default(true)
  subscriptions     Subscription[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Subscription {
  id                     String             @id @default(cuid())
  shopId                 String
  billingPlanId          String
  status                 SubscriptionStatus @default(ACTIVE)
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  skuCount               Int                @default(0)
  locationCount          Int                @default(0)
  storeCount             Int                @default(1)
  overageAmountCents     Int                @default(0)
  externalCustomerId     String?
  externalSubscriptionId String?
  billingPlan            BillingPlan        @relation(fields: [billingPlanId], references: [id])
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([shopId, status])
}

model FeatureFlag {
  id        String          @id @default(cuid())
  shopId    String
  key       String
  plan      BillingPlanKey?
  enabled   Boolean         @default(false)
  config    Json?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([shopId, key])
}

model AIConversation {
  id           String         @id @default(cuid())
  shopId       String
  userId       String?
  title        String
  intent       String?
  dataSnapshot Json?
  messages     AIMessage[]
  pins         AIInsightPin[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([shopId, updatedAt])
}

model AIMessage {
  id             String         @id @default(cuid())
  shopId         String
  conversationId String
  role           AIMessageRole
  content        String
  tokens         Int?
  model          String?
  metadata       Json?
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@index([shopId, conversationId, createdAt])
}

model AIInsightPin {
  id              String          @id @default(cuid())
  shopId          String
  conversationId  String?
  title           String
  insight         String
  confidence      String          @default("Medium")
  sourceMessageId String?
  tags            Json?
  createdBy       String?
  conversation    AIConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([shopId, createdAt])
}

model MigrationJob {
  id            String             @id @default(cuid())
  shopId        String
  source        String             @default("Stocky")
  status        MigrationJobStatus @default(DRAFT)
  dryRun        Boolean            @default(true)
  fieldMapping  Json
  summary       Json?
  rollbackToken String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdBy     String?
  logs          MigrationLog[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([shopId, status])
}

model MigrationLog {
  id         String              @id @default(cuid())
  shopId     String
  jobId      String
  entityType MigrationEntityType
  rowNumber  Int?
  level      String              @default("INFO")
  message    String
  rawRow     Json?
  mappedRow  Json?
  importedId String?
  skipped    Boolean             @default(false)
  reason     String?
  job        MigrationJob        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt  DateTime            @default(now())

  @@index([shopId, jobId, entityType])
}

model ScenarioSimulation {
  id         String   @id @default(cuid())
  shopId     String
  name       String
  inputs     Json
  outputs    Json
  monteCarlo Json?
  createdBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shopId, createdAt])
}

model CompetitorPrice {
  id             String          @id @default(cuid())
  shopId         String
  variantId      String?
  sku            String
  competitorName String
  url            String
  observedPrice  Decimal         @db.Decimal(12, 2)
  merchantPrice  Decimal?        @db.Decimal(12, 2)
  currency       String          @default("USD")
  observedAt     DateTime        @default(now())
  recommendation String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([shopId, sku, observedAt])
}

model WhiteLabelConfig {
  id            String   @id @default(cuid())
  shopId        String   @unique
  agencyName    String
  brandName     String
  logoUrl       String?
  primaryColor  String   @default("#0f766e")
  accentColor   String   @default("#111827")
  supportEmail  String
  customDomain  String?
  emailBranding Json?
  pdfBranding   Json?
  active        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model APIKey {
  id         String    @id @default(cuid())
  shopId     String
  name       String
  prefix     String    @unique
  keyHash    String
  scopes     Json
  active     Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdBy  String?
  createdAt  DateTime  @default(now())

  @@index([shopId, active])
}
